from abc import ABC, abstractmethod
import datetime

# ==============================
# ARCHIVO LOG
# ==============================
def registrar_log(mensaje):
    with open("log.txt", "a") as archivo:
        archivo.write(f"{datetime.datetime.now()} - {mensaje}\n")


